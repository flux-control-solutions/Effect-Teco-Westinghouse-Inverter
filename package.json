{
  "name": "effect-teco-westinghouse-inverter",
  "version": "1.0.0",
  "description": "Bidirectional schema transformers for Teco/Westinghouse A510 inverter Modbus parameters.",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    }
  },
  "scripts": {
    "test": "bun test src/schemas.test.ts src/parameters/",
    "test:coverage": "bun test --coverage src/schemas.test.ts src/parameters/",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf ./dist && bun build ./index.ts --outdir ./dist --target node --external effect --external effect-modbus-rs --external modbus-rs --external modbus-schema && tsc --noEmit false --emitDeclarationOnly --outDir ./dist --rootDir . --project tsconfig.build.json"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.4",
    "@effect/platform-bun": "^0.90.0",
    "@types/bun": "latest",
    "effect": "^3.21.4",
    "fallow": "^2.104.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "effect": "^3.21.4"
  },
  "dependencies": {
    "effect-modbus-rs": "github:flux-control-solutions/Effect-modbus-rs",
    "modbus-schema": "github:flux-control-solutions/modbus-schema"
  },
  "license": "GPL-3.0"
}
